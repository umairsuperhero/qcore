FROM golang:1.23-alpine AS builder

WORKDIR /build

COPY go.mod go.sum ./
RUN go mod download

COPY . .

ARG VERSION=dev
ARG COMMIT=none
ARG BUILD_DATE=unknown

RUN CGO_ENABLED=0 GOOS=linux go build \
    -ldflags "-X main.version=${VERSION} -X main.commit=${COMMIT} -X main.buildDate=${BUILD_DATE}" \
    -o /qcore-hss ./cmd/hss

FROM alpine:3.19

RUN apk --no-cache add ca-certificates

COPY --from=builder /qcore-hss /usr/local/bin/qcore-hss
COPY config.example.yaml /etc/qcore/config.yaml

EXPOSE 8080 9090

ENTRYPOINT ["qcore-hss"]
CMD ["start", "--config", "/etc/qcore/config.yaml"]
